# Copy this file to .env.local and fill in your own values.
# NEVER commit .env or .env.local – they are listed in .gitignore.

# ----- Clerk authentication -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_key
CLERK_SECRET_KEY=sk_test_replace_with_your_key

# ----- MongoDB Atlas (SRV connection string) -----
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net[/<dbname>]
# If no database name is included, the app defaults to "quickcart".
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net

# ----- Currency -----
NEXT_PUBLIC_CURRENCY=MMK

# ----- Inngest -----
INNGEST_SIGNING_KEY=replace_with_your_signing_key
INNGEST_EVENT_KEY=replace_with_your_event_key

# ----- Cloudinary -----
CLOUDINARY_CLOUD_NAME=replace_with_your_cloud_name
CLOUDINARY_API_KEY=replace_with_your_api_key
CLOUDINARY_API_SECRET=replace_with_your_api_secret
